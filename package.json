{
	"private": true,
	"name": "ai-cost-usage-tracker",
	"version": "9.3.0",
	"description": "Pinned versions and SRI hashes for vendored libraries in lib/.",
	"scripts": {
		"test": "node --test tests/unit/*.test.mjs",
		"test:unit": "node --test tests/unit/*.test.mjs",
		"test:e2e": "playwright test",
		"test:e2e:headed": "playwright test --headed",
		"test:e2e:install": "playwright install chromium",
		"audit": "node scripts/audit-debug-privacy.js && node scripts/check-dataclasses.js",
		"verify": "python3 scripts/run_checks.py quick",
		"verify:all": "python3 scripts/run_checks.py all",
		"release": "node scripts/release-build.js chrome",
		"release:chrome": "node scripts/release-build.js chrome",
		"release:firefox": "node scripts/release-build.js firefox",
		"release:all": "node scripts/release-build.js all"
	},
	"vendoredDependencies": {
		"webextension-polyfill": {
			"version": "0.12.0",
			"file": "lib/browser-polyfill.min.js",
			"source": "https://github.com/nicolo-ribaudo/webextension-polyfill",
			"license": "MPL-2.0"
		},
		"gpt-tokenizer-o200k-base": {
			"file": "lib/o200k_base.js",
			"source": "https://github.com/nicolo-ribaudo/gpt-tokenizer",
			"license": "MIT",
			"note": "UMD bundle of GPTTokenizer_o200k_base; version not embedded in minified output"
		}
	},
	"devDependencies": {
		"@playwright/test": "^1.59.1",
		"web-ext": "^10.1.0"
	}
}
