{
	"private": true,
	"name": "ai-cost-usage-tracker",
	"version": "9.2.0",
	"description": "Pinned versions and SRI hashes for vendored libraries in lib/.",
	"scripts": {
		"test": "node --test tests/unit/*.test.js",
		"test:unit": "node --test tests/unit/*.test.js",
		"test:e2e": "playwright test",
		"test:e2e:headed": "playwright test --headed",
		"test:e2e:install": "playwright install chromium",
		"check:syntax": "node scripts/check-syntax.js",
		"check:privacy": "node scripts/audit-debug-privacy.js",
		"check:dataclasses": "node scripts/check-dataclasses.js",
		"check:handlers": "node scripts/check-handler-count.js",
		"validate": "npm run check:syntax && npm run check:privacy && npm run check:dataclasses && npm run check:handlers && npm test"
	},
	"vendoredDependencies": {
		"webextension-polyfill": {
			"version": "0.12.0",
			"file": "lib/browser-polyfill.min.js",
			"source": "https://github.com/nicolo-ribaudo/webextension-polyfill",
			"license": "MPL-2.0"
		},
		"gpt-tokenizer-o200k-base": {
			"file": "lib/o200k_base.js",
			"source": "https://github.com/nicolo-ribaudo/gpt-tokenizer",
			"license": "MIT",
			"note": "UMD bundle of GPTTokenizer_o200k_base; version not embedded in minified output"
		}
	},
	"devDependencies": {
		"@playwright/test": "^1.59.1"
	}
}
